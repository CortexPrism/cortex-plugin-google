{
  "name": "cortex-plugin-google",
  "version": "1.0.0",
  "description": "Comprehensive Google Workspace integration — Gmail, Calendar, Drive, Docs, Sheets, and Google News in one plugin",
  "kind": "esm",
  "entryPoint": "mod.ts",
  "runtime": "deno",
  "author": "CortexPrism Contributors",
  "license": "MIT",
  "repository": "https://github.com/CortexPrism/cortex-plugin-google",
  "homepage": "https://github.com/CortexPrism/cortex-plugin-google",
  "capabilities": [
    "tools",
    "network:fetch",
    "config:auth"
  ],
  "tools": [
    {
      "name": "gmail_list",
      "description": "List Gmail messages with optional filters (query, maxResults, labelIds)",
      "params": [
        {
          "name": "query",
          "type": "string",
          "description": "Gmail search query (e.g., 'from:alice is:unread')",
          "required": false
        },
        {
          "name": "maxResults",
          "type": "number",
          "description": "Maximum number of messages to return (1-500, default 20)",
          "required": false
        },
        {
          "name": "labelIds",
          "type": "string",
          "description": "Comma-separated label IDs to filter by (e.g., 'INBOX,UNREAD')",
          "required": false
        }
      ]
    },
    {
      "name": "gmail_get",
      "description": "Get full content of a specific Gmail message by ID",
      "params": [
        {
          "name": "messageId",
          "type": "string",
          "description": "The Gmail message ID to retrieve",
          "required": true
        },
        {
          "name": "format",
          "type": "string",
          "description": "Message format: 'full', 'raw', 'minimal', or 'metadata' (default: full)",
          "required": false
        }
      ]
    },
    {
      "name": "gmail_send",
      "description": "Send an email via Gmail",
      "params": [
        {
          "name": "to",
          "type": "string",
          "description": "Recipient email address(es), comma-separated for multiple",
          "required": true
        },
        {
          "name": "subject",
          "type": "string",
          "description": "Email subject line",
          "required": true
        },
        {
          "name": "body",
          "type": "string",
          "description": "Email body content (plain text or HTML)",
          "required": true
        },
        {
          "name": "cc",
          "type": "string",
          "description": "CC recipient(s), comma-separated",
          "required": false
        },
        {
          "name": "bcc",
          "type": "string",
          "description": "BCC recipient(s), comma-separated",
          "required": false
        },
        {
          "name": "isHtml",
          "type": "boolean",
          "description": "Set to true if body contains HTML (default: false)",
          "required": false
        }
      ]
    },
    {
      "name": "gmail_search",
      "description": "Search Gmail messages using Gmail search syntax",
      "params": [
        {
          "name": "query",
          "type": "string",
          "description": "Gmail search query (supports operators like from:, to:, subject:, after:, before:, has:attachment, etc.)",
          "required": true
        },
        {
          "name": "maxResults",
          "type": "number",
          "description": "Maximum number of results (1-500, default 20)",
          "required": false
        }
      ]
    },
    {
      "name": "gmail_modify",
      "description": "Modify Gmail message labels (mark as read, archive, trash, etc.)",
      "params": [
        {
          "name": "messageId",
          "type": "string",
          "description": "The Gmail message ID to modify",
          "required": true
        },
        {
          "name": "addLabelIds",
          "type": "string",
          "description": "Comma-separated label IDs to add (e.g., 'TRASH,UNREAD')",
          "required": false
        },
        {
          "name": "removeLabelIds",
          "type": "string",
          "description": "Comma-separated label IDs to remove (e.g., 'INBOX,UNREAD')",
          "required": false
        }
      ]
    },
    {
      "name": "gmail_list_labels",
      "description": "List all Gmail labels for the authenticated account",
      "params": []
    },
    {
      "name": "calendar_list_events",
      "description": "List calendar events with optional time range and filters",
      "params": [
        {
          "name": "calendarId",
          "type": "string",
          "description": "Calendar ID (default: 'primary')",
          "required": false
        },
        {
          "name": "timeMin",
          "type": "string",
          "description": "Start of time range in ISO 8601 format (e.g., '2026-06-01T00:00:00Z')",
          "required": false
        },
        {
          "name": "timeMax",
          "type": "string",
          "description": "End of time range in ISO 8601 format",
          "required": false
        },
        {
          "name": "maxResults",
          "type": "number",
          "description": "Maximum events to return (1-2500, default 50)",
          "required": false
        },
        {
          "name": "query",
          "type": "string",
          "description": "Free-text search term to filter events",
          "required": false
        },
        {
          "name": "singleEvents",
          "type": "boolean",
          "description": "Expand recurring events into instances (default: true)",
          "required": false
        }
      ]
    },
    {
      "name": "calendar_create_event",
      "description": "Create a new calendar event",
      "params": [
        {
          "name": "summary",
          "type": "string",
          "description": "Event title",
          "required": true
        },
        {
          "name": "startDateTime",
          "type": "string",
          "description": "Start date/time in ISO 8601 format (e.g., '2026-07-01T09:00:00-05:00')",
          "required": true
        },
        {
          "name": "endDateTime",
          "type": "string",
          "description": "End date/time in ISO 8601 format",
          "required": true
        },
        {
          "name": "description",
          "type": "string",
          "description": "Event description or body",
          "required": false
        },
        {
          "name": "location",
          "type": "string",
          "description": "Event location (text or address)",
          "required": false
        },
        {
          "name": "calendarId",
          "type": "string",
          "description": "Calendar ID (default: 'primary')",
          "required": false
        },
        {
          "name": "attendees",
          "type": "string",
          "description": "Comma-separated attendee email addresses",
          "required": false
        },
        {
          "name": "timeZone",
          "type": "string",
          "description": "Time zone for the event (e.g., 'America/New_York')",
          "required": false
        }
      ]
    },
    {
      "name": "calendar_update_event",
      "description": "Update an existing calendar event",
      "params": [
        {
          "name": "eventId",
          "type": "string",
          "description": "The event ID to update",
          "required": true
        },
        {
          "name": "summary",
          "type": "string",
          "description": "New event title",
          "required": false
        },
        {
          "name": "startDateTime",
          "type": "string",
          "description": "New start date/time in ISO 8601 format",
          "required": false
        },
        {
          "name": "endDateTime",
          "type": "string",
          "description": "New end date/time in ISO 8601 format",
          "required": false
        },
        {
          "name": "description",
          "type": "string",
          "description": "New event description",
          "required": false
        },
        {
          "name": "location",
          "type": "string",
          "description": "New event location",
          "required": false
        },
        {
          "name": "calendarId",
          "type": "string",
          "description": "Calendar ID (default: 'primary')",
          "required": false
        }
      ]
    },
    {
      "name": "calendar_delete_event",
      "description": "Delete a calendar event",
      "params": [
        {
          "name": "eventId",
          "type": "string",
          "description": "The event ID to delete",
          "required": true
        },
        {
          "name": "calendarId",
          "type": "string",
          "description": "Calendar ID (default: 'primary')",
          "required": false
        }
      ]
    },
    {
      "name": "calendar_list_calendars",
      "description": "List all calendars the authenticated user has access to",
      "params": []
    },
    {
      "name": "drive_list_files",
      "description": "List files and folders in Google Drive with optional filters",
      "params": [
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of files to return (1-1000, default 20)",
          "required": false
        },
        {
          "name": "query",
          "type": "string",
          "description": "Drive search query (e.g., \"mimeType='application/vnd.google-apps.folder'\")",
          "required": false
        },
        {
          "name": "orderBy",
          "type": "string",
          "description": "Sort order (e.g., 'modifiedTime desc,name')",
          "required": false
        },
        {
          "name": "fields",
          "type": "string",
          "description": "Comma-separated fields to include (default: 'files(id,name,mimeType,size,modifiedTime,webViewLink)')",
          "required": false
        }
      ]
    },
    {
      "name": "drive_get_file",
      "description": "Get file metadata or content from Google Drive",
      "params": [
        {
          "name": "fileId",
          "type": "string",
          "description": "The Drive file ID",
          "required": true
        },
        {
          "name": "download",
          "type": "boolean",
          "description": "Download file content (default: false, returns metadata only)",
          "required": false
        }
      ]
    },
    {
      "name": "drive_upload_file",
      "description": "Upload a file to Google Drive",
      "params": [
        {
          "name": "name",
          "type": "string",
          "description": "Filename to use in Drive",
          "required": true
        },
        {
          "name": "content",
          "type": "string",
          "description": "Base64-encoded file content or plain text content",
          "required": true
        },
        {
          "name": "mimeType",
          "type": "string",
          "description": "MIME type of the file (e.g., 'text/plain', 'application/pdf')",
          "required": false
        },
        {
          "name": "parentFolderId",
          "type": "string",
          "description": "ID of the parent folder to upload into",
          "required": false
        },
        {
          "name": "isBase64",
          "type": "boolean",
          "description": "Set to true if content is base64-encoded (default: false)",
          "required": false
        }
      ]
    },
    {
      "name": "drive_create_folder",
      "description": "Create a new folder in Google Drive",
      "params": [
        {
          "name": "name",
          "type": "string",
          "description": "Folder name",
          "required": true
        },
        {
          "name": "parentFolderId",
          "type": "string",
          "description": "ID of the parent folder (root if not specified)",
          "required": false
        }
      ]
    },
    {
      "name": "drive_delete_file",
      "description": "Delete a file or folder from Google Drive (moves to trash)",
      "params": [
        {
          "name": "fileId",
          "type": "string",
          "description": "The Drive file/folder ID to delete",
          "required": true
        }
      ]
    },
    {
      "name": "drive_search",
      "description": "Search Google Drive for files by name, content, or type",
      "params": [
        {
          "name": "query",
          "type": "string",
          "description": "Drive search query (e.g., \"name contains 'report'\")",
          "required": true
        },
        {
          "name": "pageSize",
          "type": "number",
          "description": "Number of results (1-100, default 20)",
          "required": false
        }
      ]
    },
    {
      "name": "docs_get",
      "description": "Read a Google Doc content by document ID",
      "params": [
        {
          "name": "documentId",
          "type": "string",
          "description": "The Google Docs document ID",
          "required": true
        }
      ]
    },
    {
      "name": "docs_create",
      "description": "Create a new Google Doc",
      "params": [
        {
          "name": "title",
          "type": "string",
          "description": "Document title",
          "required": true
        },
        {
          "name": "content",
          "type": "string",
          "description": "Initial text content for the document",
          "required": false
        }
      ]
    },
    {
      "name": "docs_update",
      "description": "Append content to an existing Google Doc",
      "params": [
        {
          "name": "documentId",
          "type": "string",
          "description": "The Google Docs document ID",
          "required": true
        },
        {
          "name": "content",
          "type": "string",
          "description": "Text content to append to the document",
          "required": true
        }
      ]
    },
    {
      "name": "sheets_get_values",
      "description": "Read cell values from a Google Sheet",
      "params": [
        {
          "name": "spreadsheetId",
          "type": "string",
          "description": "The spreadsheet ID",
          "required": true
        },
        {
          "name": "range",
          "type": "string",
          "description": "A1 notation range (e.g., 'Sheet1!A1:D10')",
          "required": true
        }
      ]
    },
    {
      "name": "sheets_update_values",
      "description": "Write values to a Google Sheet range",
      "params": [
        {
          "name": "spreadsheetId",
          "type": "string",
          "description": "The spreadsheet ID",
          "required": true
        },
        {
          "name": "range",
          "type": "string",
          "description": "A1 notation range (e.g., 'Sheet1!A1:D10')",
          "required": true
        },
        {
          "name": "values",
          "type": "string",
          "description": "2D array of values in JSON format (e.g., '[[\"Name\",\"Age\"],[\"Alice\",\"30\"]]')",
          "required": true
        }
      ]
    },
    {
      "name": "sheets_create",
      "description": "Create a new Google Sheet",
      "params": [
        {
          "name": "title",
          "type": "string",
          "description": "Spreadsheet title",
          "required": true
        },
        {
          "name": "sheets",
          "type": "string",
          "description": "Comma-separated sheet/tab names to create (default: 'Sheet1')",
          "required": false
        }
      ]
    },
    {
      "name": "sheets_append_rows",
      "description": "Append rows to a Google Sheet",
      "params": [
        {
          "name": "spreadsheetId",
          "type": "string",
          "description": "The spreadsheet ID",
          "required": true
        },
        {
          "name": "range",
          "type": "string",
          "description": "The range where to append (e.g., 'Sheet1!A1:C1')",
          "required": true
        },
        {
          "name": "values",
          "type": "string",
          "description": "2D array of values in JSON format (e.g., '[[\"Name\",\"Age\"],[\"Alice\",\"30\"]]')",
          "required": true
        }
      ]
    },
    {
      "name": "sheets_get_spreadsheet",
      "description": "Get spreadsheet metadata including sheet names and properties",
      "params": [
        {
          "name": "spreadsheetId",
          "type": "string",
          "description": "The spreadsheet ID",
          "required": true
        }
      ]
    },
    {
      "name": "news_get_headlines",
      "description": "Get top news headlines. Requires a NewsAPI key configured in plugin settings.",
      "params": [
        {
          "name": "country",
          "type": "string",
          "description": "Two-letter country code (e.g., 'us', 'gb', 'ca'). Default: 'us'",
          "required": false
        },
        {
          "name": "category",
          "type": "string",
          "description": "News category (business, entertainment, general, health, science, sports, technology)",
          "required": false
        },
        {
          "name": "maxResults",
          "type": "number",
          "description": "Number of headlines (1-100, default 10)",
          "required": false
        }
      ]
    },
    {
      "name": "news_search",
      "description": "Search Google News articles by keyword. Requires a NewsAPI key configured in plugin settings.",
      "params": [
        {
          "name": "query",
          "type": "string",
          "description": "Search keywords or phrase",
          "required": true
        },
        {
          "name": "maxResults",
          "type": "number",
          "description": "Number of results (1-100, default 10)",
          "required": false
        },
        {
          "name": "sortBy",
          "type": "string",
          "description": "Sort order: 'relevancy', 'popularity', or 'publishedAt'. Default: 'publishedAt'",
          "required": false
        },
        {
          "name": "from",
          "type": "string",
          "description": "Start date in ISO 8601 format (e.g., '2026-06-01')",
          "required": false
        },
        {
          "name": "to",
          "type": "string",
          "description": "End date in ISO 8601 format",
          "required": false
        }
      ]
    }
  ],
  "config": {
    "properties": {
      "google": {
        "type": "object",
        "required": ["clientId", "clientSecret", "refreshToken"],
        "properties": {
          "clientId": {
            "type": "string",
            "description": "Google OAuth 2.0 Client ID from Google Cloud Console"
          },
          "clientSecret": {
            "type": "string",
            "description": "Google OAuth 2.0 Client Secret"
          },
          "refreshToken": {
            "type": "string",
            "description": "OAuth 2.0 Refresh Token for offline access"
          },
          "scopes": {
            "type": "string",
            "description": "Space-separated OAuth scopes (auto-configured based on capabilities used)"
          }
        }
      },
      "newsapi": {
        "type": "object",
        "properties": {
          "apiKey": {
            "type": "string",
            "description": "NewsAPI.org API key for Google News access"
          }
        }
      }
    }
  },
  "dependencies": {},
  "peerDependencies": {
    "cortex": ">=1.0.0"
  },
  "aiDisclosure": {
    "tools": ["copilot"],
    "generatedFiles": [
      "mod.ts",
      "auth.ts",
      "services/gmail.ts",
      "services/calendar.ts",
      "services/drive.ts",
      "services/docs.ts",
      "services/sheets.ts",
      "services/news.ts",
      "README.md"
    ],
    "humanReviewed": true,
    "statement": "All AI-generated code was reviewed, tested, and verified for correctness and security."
  }
}
